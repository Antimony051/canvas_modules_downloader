# Canvas Module Downloader Configuration
# Copy this file to credentials.yaml and fill in your details

# The URL of your Canvas instance (e.g., https://your-school.instructure.com)
API_URL: https://example.instructure.com

# Your Canvas API token
# Get this from Canvas: Account > Settings > Approved Integrations > + New Access Token
API_KEY: your_api_token_here

# Your Canvas User ID
# Get this from: https://<your-canvas-url>/api/v1/users/self (look for "id" field)
USER_ID: 123456